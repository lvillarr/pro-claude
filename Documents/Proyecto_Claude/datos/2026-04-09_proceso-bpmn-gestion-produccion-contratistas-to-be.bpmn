<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://arauco.com/mejora-continua/bpmn"
             id="Definitions_GestionContratistas_TOBE">

  <process id="Process_GestionContratistas_TOBE" name="Gestión Producción Contratistas — TO-BE" isExecutable="false">

    <laneSet id="LaneSet_1">
      <lane id="Lane_AreaContratos" name="Área Contratos">
        <flowNodeRef>Start_1</flowNodeRef>
        <flowNodeRef>Task_GenerarContrato</flowNodeRef>
      </lane>
      <lane id="Lane_LiderOperaciones" name="Líder de Operaciones">
        <flowNodeRef>Start_Timer_Diario</flowNodeRef>
        <flowNodeRef>Task_NotificarProduccion</flowNodeRef>
      </lane>
      <lane id="Lane_EncargadoCosecha" name="Encargado Cosecha">
        <flowNodeRef>Task_CreacionActasDigital</flowNodeRef>
      </lane>
      <lane id="Lane_AnalistaLogistico" name="Analista C. Producción Logístico">
        <flowNodeRef>Task_ValidacionNOC</flowNodeRef>
        <flowNodeRef>GW_EsNOC</flowNodeRef>
        <flowNodeRef>Task_CorreccionEstandar</flowNodeRef>
        <flowNodeRef>Task_ProcesoInventario</flowNodeRef>
        <flowNodeRef>Task_PreliminarNOC</flowNodeRef>
        <flowNodeRef>Start_Timer_Noche</flowNodeRef>
        <flowNodeRef>Task_CreacionPedidos</flowNodeRef>
      </lane>
      <lane id="Lane_AnalistaValorizado" name="Analista C. Producción Valorizado">
        <flowNodeRef>GW_Split_Contratos</flowNodeRef>
        <flowNodeRef>Task_CreacionContratoSAP</flowNodeRef>
        <flowNodeRef>Task_CreacionContratoMA</flowNodeRef>
        <flowNodeRef>Task_CreacionContratoCDH</flowNodeRef>
        <flowNodeRef>GW_Join_Contratos</flowNodeRef>
        <flowNodeRef>Task_IntegracionSistemas</flowNodeRef>
        <flowNodeRef>End_ContratosCreados</flowNodeRef>
        <flowNodeRef>GW_CambiosVMA</flowNodeRef>
        <flowNodeRef>Task_GestionModificacionesVMA</flowNodeRef>
        <flowNodeRef>Task_ActualizaVariables</flowNodeRef>
        <flowNodeRef>Task_CalculaTarifas</flowNodeRef>
        <flowNodeRef>Task_ConciliaProduccion</flowNodeRef>
        <flowNodeRef>Task_ValoraProduccion</flowNodeRef>
        <flowNodeRef>Task_GeneraReporteSAP</flowNodeRef>
        <flowNodeRef>GW_ExistenDiferencias</flowNodeRef>
        <flowNodeRef>Task_TramitaErrores</flowNodeRef>
        <flowNodeRef>Task_DaVoBo</flowNodeRef>
        <flowNodeRef>Task_EnviaReportes</flowNodeRef>
        <flowNodeRef>End_Excepcion</flowNodeRef>
      </lane>
      <lane id="Lane_AnalistaTerreno" name="Analista C. Producción Terreno">
        <flowNodeRef>Task_CierreActas</flowNodeRef>
      </lane>
      <lane id="Lane_JefeProduccion" name="Jefe Producción Contratista">
        <flowNodeRef>Task_AprobacionValorizado</flowNodeRef>
      </lane>
      <lane id="Lane_Contratista" name="Contratista / Contratante">
        <flowNodeRef>Task_GeneraMemoAvance</flowNodeRef>
        <flowNodeRef>End_ProcesoOK</flowNodeRef>
      </lane>
    </laneSet>

    <!-- ============================================================ -->
    <!-- FASE 1: CREACIÓN CONTRATO Y ACTAS — TO-BE                   -->
    <!-- Mejora: contratos creados en paralelo con integración        -->
    <!-- automática SAP↔MA↔CDH al finalizar                          -->
    <!-- ============================================================ -->

    <!-- Área Contratos -->
    <startEvent id="Start_1" name="Inicio proceso contratación">
      <outgoing>Flow_1</outgoing>
    </startEvent>
    <userTask id="Task_GenerarContrato" name="Generar contrato">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2a</outgoing>
      <outgoing>Flow_2b</outgoing>
      <!-- VAN -->
    </userTask>

    <!-- Encargado Cosecha: captura digital estandarizada -->
    <userTask id="Task_CreacionActasDigital" name="Creación de actas (digital estandarizado)">
      <incoming>Flow_2a</incoming>
      <outgoing>Flow_Actas_out</outgoing>
      <!-- VA: Captura en sistema, sin papel ni datos libres — elimina duplicados y desvíos de origen -->
    </userTask>

    <!-- Analista Valorizado: contratos paralelos automáticos -->
    <parallelGateway id="GW_Split_Contratos" name="">
      <incoming>Flow_2b</incoming>
      <outgoing>Flow_SAP_in</outgoing>
      <outgoing>Flow_MA_in</outgoing>
      <outgoing>Flow_CDH_in</outgoing>
    </parallelGateway>
    <serviceTask id="Task_CreacionContratoSAP" name="Crear contrato SAP (automatizado)">
      <incoming>Flow_SAP_in</incoming>
      <outgoing>Flow_SAP_out</outgoing>
      <!-- VAN: serviceTask — ejecutado por integración API -->
    </serviceTask>
    <serviceTask id="Task_CreacionContratoMA" name="Crear contrato MA (automatizado)">
      <incoming>Flow_MA_in</incoming>
      <outgoing>Flow_MA_out</outgoing>
      <!-- VAN -->
    </serviceTask>
    <serviceTask id="Task_CreacionContratoCDH" name="Crear contrato CDH (automatizado)">
      <incoming>Flow_CDH_in</incoming>
      <outgoing>Flow_CDH_out</outgoing>
      <!-- VAN -->
    </serviceTask>
    <parallelGateway id="GW_Join_Contratos" name="">
      <incoming>Flow_SAP_out</incoming>
      <incoming>Flow_MA_out</incoming>
      <incoming>Flow_CDH_out</incoming>
      <outgoing>Flow_Join_out</outgoing>
    </parallelGateway>
    <serviceTask id="Task_IntegracionSistemas" name="Sincronización automática SAP ↔ MA ↔ CDH">
      <incoming>Flow_Join_out</incoming>
      <outgoing>Flow_Integ_out</outgoing>
      <!-- VAN: Integración en tiempo real — elimina cuadratura manual mensual -->
    </serviceTask>
    <endEvent id="End_ContratosCreados" name="Contratos sincronizados en todos los sistemas">
      <incoming>Flow_Integ_out</incoming>
    </endEvent>

    <!-- ============================================================ -->
    <!-- FASE 2: REVISIÓN PRODUCCIÓN — TO-BE                         -->
    <!-- Mejora: captura estandarizada elimina rama Duplicado/         -->
    <!-- Tendencia; corrección única si hay desvío; sin cuadratura    -->
    <!-- mensual (reemplazada por integración tiempo real)             -->
    <!-- ============================================================ -->

    <!-- Líder Operaciones: notificación diaria -->
    <startEvent id="Start_Timer_Diario" name="Cada día (timer)">
      <timerEventDefinition/>
      <outgoing>Flow_Timer_Diario</outgoing>
    </startEvent>
    <serviceTask id="Task_NotificarProduccion" name="Notificar producción diaria (automático)">
      <incoming>Flow_Timer_Diario</incoming>
      <outgoing>Flow_Notif_out</outgoing>
      <!-- VAN: Automatizado -->
    </serviceTask>

    <!-- Analista Logístico: validación NOC simplificada -->
    <userTask id="Task_ValidacionNOC" name="Validación Acta/NOC">
      <incoming>Flow_Notif_out</incoming>
      <incoming>Flow_Actas_out</incoming>
      <outgoing>Flow_ValidNOC</outgoing>
      <!-- VA: Control clave de calidad del dato -->
    </userTask>
    <exclusiveGateway id="GW_EsNOC" name="¿NOC ok?">
      <incoming>Flow_ValidNOC</incoming>
      <outgoing>Flow_NOC_Si</outgoing>
      <outgoing>Flow_NOC_No</outgoing>
    </exclusiveGateway>

    <!-- Rama NO: corrección única estandarizada (no hay 3 ramas) -->
    <userTask id="Task_CorreccionEstandar" name="Corrección estandarizada (asistida por sistema)">
      <incoming>Flow_NOC_No</incoming>
      <outgoing>Flow_Corr_out</outgoing>
      <!-- NVA residual: reducido por captura digital estandarizada en origen -->
    </userTask>

    <!-- Confluencia y proceso inventario -->
    <serviceTask id="Task_ProcesoInventario" name="Proceso de inventario (automático)">
      <incoming>Flow_NOC_Si</incoming>
      <incoming>Flow_Corr_out</incoming>
      <outgoing>Flow_Inv_out</outgoing>
      <!-- VAN -->
    </serviceTask>
    <userTask id="Task_PreliminarNOC" name="Preliminar Acta/NOC">
      <incoming>Flow_Inv_out</incoming>
      <outgoing>Flow_Prel_out</outgoing>
      <!-- VA: Consolidación para pedidos -->
    </userTask>

    <!-- Timer noche: creación pedidos -->
    <startEvent id="Start_Timer_Noche" name="Cada noche (timer)">
      <timerEventDefinition/>
      <outgoing>Flow_Timer_Noche</outgoing>
    </startEvent>
    <serviceTask id="Task_CreacionPedidos" name="Creación pedidos (automático)">
      <incoming>Flow_Timer_Noche</incoming>
      <incoming>Flow_Prel_out</incoming>
      <outgoing>Flow_Pedidos_out</outgoing>
      <!-- VAN: Automatizado -->
    </serviceTask>

    <!-- ============================================================ -->
    <!-- FASE 3: VALORIZACIÓN — TO-BE                                 -->
    <!-- Mejora: reporte automático SAP/Power BI reemplaza Excel      -->
    <!-- EEGMM; máximo 2 eventos de fin (OK + Excepción)              -->
    <!-- ============================================================ -->

    <!-- Cambios VMA -->
    <exclusiveGateway id="GW_CambiosVMA" name="¿Cambios VMA?">
      <incoming>Flow_Pedidos_out</incoming>
      <outgoing>Flow_VMA_Si</outgoing>
      <outgoing>Flow_VMA_No</outgoing>
    </exclusiveGateway>
    <userTask id="Task_GestionModificacionesVMA" name="Gestión modificaciones VMA">
      <incoming>Flow_VMA_Si</incoming>
      <outgoing>Flow_VMA_out</outgoing>
      <!-- VAN: Gestión excepcional de cambios tarifarios -->
    </userTask>

    <!-- Flujo valorización principal -->
    <userTask id="Task_ActualizaVariables" name="Actualiza variables">
      <incoming>Flow_VMA_No</incoming>
      <incoming>Flow_VMA_out</incoming>
      <outgoing>Flow_AV_out</outgoing>
      <!-- VA -->
    </userTask>
    <userTask id="Task_CalculaTarifas" name="Calcula tarifas">
      <incoming>Flow_AV_out</incoming>
      <outgoing>Flow_CT_out</outgoing>
      <!-- VA -->
    </userTask>

    <!-- Analista Terreno: cierre actas -->
    <userTask id="Task_CierreActas" name="Cierre de actas">
      <incoming>Flow_CT_out</incoming>
      <outgoing>Flow_CA_out</outgoing>
      <!-- VA -->
    </userTask>

    <userTask id="Task_ConciliaProduccion" name="Concilia producción">
      <incoming>Flow_CA_out</incoming>
      <outgoing>Flow_CP_out</outgoing>
      <!-- VA -->
    </userTask>
    <userTask id="Task_ValoraProduccion" name="Valora producción">
      <incoming>Flow_CP_out</incoming>
      <outgoing>Flow_VP_out</outgoing>
      <!-- VA -->
    </userTask>

    <!-- MEJORA CLAVE: Reporte automático SAP/Power BI reemplaza Excel EEGMM -->
    <serviceTask id="Task_GeneraReporteSAP" name="Generar reporte valorizado SAP / Power BI (automático)">
      <incoming>Flow_VP_out</incoming>
      <outgoing>Flow_Rpt_out</outgoing>
      <!-- VA: Automatizado — elimina riesgo de error manual en Excel -->
    </serviceTask>

    <exclusiveGateway id="GW_ExistenDiferencias" name="¿Diferencias?">
      <incoming>Flow_Rpt_out</incoming>
      <outgoing>Flow_Dif_No</outgoing>
      <outgoing>Flow_Dif_Si</outgoing>
    </exclusiveGateway>

    <!-- Rama excepción: tramitar errores -->
    <userTask id="Task_TramitaErrores" name="Tramitar errores">
      <incoming>Flow_Dif_Si</incoming>
      <outgoing>Flow_TE_out</outgoing>
      <!-- NVA residual -->
    </userTask>
    <endEvent id="End_Excepcion" name="Excepción registrada y escalada">
      <incoming>Flow_TE_out</incoming>
    </endEvent>

    <!-- Rama ok: aprobación y memo avance -->
    <userTask id="Task_DaVoBo" name="Dar VoBo valorizado">
      <incoming>Flow_Dif_No</incoming>
      <outgoing>Flow_VoBo_out</outgoing>
      <!-- VAN -->
    </userTask>
    <userTask id="Task_EnviaReportes" name="Envía reportes">
      <incoming>Flow_VoBo_out</incoming>
      <outgoing>Flow_ER_out</outgoing>
      <!-- VAN -->
    </userTask>

    <!-- Jefe Producción Contratista -->
    <userTask id="Task_AprobacionValorizado" name="Aprobación valorizado">
      <incoming>Flow_ER_out</incoming>
      <outgoing>Flow_Apro_out</outgoing>
      <!-- VAN -->
    </userTask>

    <!-- Contratista: memo avance -->
    <userTask id="Task_GeneraMemoAvance" name="Generar memo de avance">
      <incoming>Flow_Apro_out</incoming>
      <outgoing>Flow_Memo_out</outgoing>
      <!-- VA: Hito de pago al contratista -->
    </userTask>
    <endEvent id="End_ProcesoOK" name="Memo de avance emitido — proceso completo">
      <incoming>Flow_Memo_out</incoming>
    </endEvent>

    <!-- ============================================================ -->
    <!-- FLUJOS DE SECUENCIA                                           -->
    <!-- ============================================================ -->

    <!-- Fase 1 -->
    <sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_GenerarContrato"/>
    <sequenceFlow id="Flow_2a" sourceRef="Task_GenerarContrato" targetRef="Task_CreacionActasDigital"/>
    <sequenceFlow id="Flow_2b" sourceRef="Task_GenerarContrato" targetRef="GW_Split_Contratos"/>
    <sequenceFlow id="Flow_SAP_in" sourceRef="GW_Split_Contratos" targetRef="Task_CreacionContratoSAP"/>
    <sequenceFlow id="Flow_MA_in" sourceRef="GW_Split_Contratos" targetRef="Task_CreacionContratoMA"/>
    <sequenceFlow id="Flow_CDH_in" sourceRef="GW_Split_Contratos" targetRef="Task_CreacionContratoCDH"/>
    <sequenceFlow id="Flow_SAP_out" sourceRef="Task_CreacionContratoSAP" targetRef="GW_Join_Contratos"/>
    <sequenceFlow id="Flow_MA_out" sourceRef="Task_CreacionContratoMA" targetRef="GW_Join_Contratos"/>
    <sequenceFlow id="Flow_CDH_out" sourceRef="Task_CreacionContratoCDH" targetRef="GW_Join_Contratos"/>
    <sequenceFlow id="Flow_Join_out" sourceRef="GW_Join_Contratos" targetRef="Task_IntegracionSistemas"/>
    <sequenceFlow id="Flow_Integ_out" sourceRef="Task_IntegracionSistemas" targetRef="End_ContratosCreados"/>

    <!-- Fase 2 -->
    <sequenceFlow id="Flow_Timer_Diario" sourceRef="Start_Timer_Diario" targetRef="Task_NotificarProduccion"/>
    <sequenceFlow id="Flow_Notif_out" sourceRef="Task_NotificarProduccion" targetRef="Task_ValidacionNOC"/>
    <sequenceFlow id="Flow_Actas_out" sourceRef="Task_CreacionActasDigital" targetRef="Task_ValidacionNOC"/>
    <sequenceFlow id="Flow_ValidNOC" sourceRef="Task_ValidacionNOC" targetRef="GW_EsNOC"/>
    <sequenceFlow id="Flow_NOC_Si" name="Sí" sourceRef="GW_EsNOC" targetRef="Task_ProcesoInventario">
      <conditionExpression>${nocOk == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_NOC_No" name="No" sourceRef="GW_EsNOC" targetRef="Task_CorreccionEstandar">
      <conditionExpression>${nocOk == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_Corr_out" sourceRef="Task_CorreccionEstandar" targetRef="Task_ProcesoInventario"/>
    <sequenceFlow id="Flow_Inv_out" sourceRef="Task_ProcesoInventario" targetRef="Task_PreliminarNOC"/>
    <sequenceFlow id="Flow_Prel_out" sourceRef="Task_PreliminarNOC" targetRef="Task_CreacionPedidos"/>
    <sequenceFlow id="Flow_Timer_Noche" sourceRef="Start_Timer_Noche" targetRef="Task_CreacionPedidos"/>
    <sequenceFlow id="Flow_Pedidos_out" sourceRef="Task_CreacionPedidos" targetRef="GW_CambiosVMA"/>

    <!-- Fase 3 -->
    <sequenceFlow id="Flow_VMA_Si" name="Sí" sourceRef="GW_CambiosVMA" targetRef="Task_GestionModificacionesVMA">
      <conditionExpression>${cambiosVMA == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_VMA_No" name="No" sourceRef="GW_CambiosVMA" targetRef="Task_ActualizaVariables">
      <conditionExpression>${cambiosVMA == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_VMA_out" sourceRef="Task_GestionModificacionesVMA" targetRef="Task_ActualizaVariables"/>
    <sequenceFlow id="Flow_AV_out" sourceRef="Task_ActualizaVariables" targetRef="Task_CalculaTarifas"/>
    <sequenceFlow id="Flow_CT_out" sourceRef="Task_CalculaTarifas" targetRef="Task_CierreActas"/>
    <sequenceFlow id="Flow_CA_out" sourceRef="Task_CierreActas" targetRef="Task_ConciliaProduccion"/>
    <sequenceFlow id="Flow_CP_out" sourceRef="Task_ConciliaProduccion" targetRef="Task_ValoraProduccion"/>
    <sequenceFlow id="Flow_VP_out" sourceRef="Task_ValoraProduccion" targetRef="Task_GeneraReporteSAP"/>
    <sequenceFlow id="Flow_Rpt_out" sourceRef="Task_GeneraReporteSAP" targetRef="GW_ExistenDiferencias"/>
    <sequenceFlow id="Flow_Dif_Si" name="Sí" sourceRef="GW_ExistenDiferencias" targetRef="Task_TramitaErrores">
      <conditionExpression>${diferencias == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_Dif_No" name="No" sourceRef="GW_ExistenDiferencias" targetRef="Task_DaVoBo">
      <conditionExpression>${diferencias == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_TE_out" sourceRef="Task_TramitaErrores" targetRef="End_Excepcion"/>
    <sequenceFlow id="Flow_VoBo_out" sourceRef="Task_DaVoBo" targetRef="Task_EnviaReportes"/>
    <sequenceFlow id="Flow_ER_out" sourceRef="Task_EnviaReportes" targetRef="Task_AprobacionValorizado"/>
    <sequenceFlow id="Flow_Apro_out" sourceRef="Task_AprobacionValorizado" targetRef="Task_GeneraMemoAvance"/>
    <sequenceFlow id="Flow_Memo_out" sourceRef="Task_GeneraMemoAvance" targetRef="End_ProcesoOK"/>

  </process>

  <!-- ============================================================ -->
  <!-- DIAGRAMA VISUAL — Coordenadas para Bizagi                    -->
  <!-- Pool horizontal: x=150, y=80 — ancho=2400, alto=1020        -->
  <!-- 8 lanes de 120px altura cada uno (etiqueta pool 30px)        -->
  <!-- ============================================================ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_GestionContratistas_TOBE">

      <!-- ── LANE: Área Contratos (y=80..200) ── -->
      <bpmndi:BPMNShape id="Start_1_di" bpmnElement="Start_1">
        <dc:Bounds x="182" y="122" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="158" y="165" width="85" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GenerarContrato_di" bpmnElement="Task_GenerarContrato">
        <dc:Bounds x="270" y="100" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- ── LANE: Líder de Operaciones (y=200..320) ── -->
      <bpmndi:BPMNShape id="Start_Timer_Diario_di" bpmnElement="Start_Timer_Diario">
        <dc:Bounds x="182" y="242" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="158" y="285" width="70" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotificarProduccion_di" bpmnElement="Task_NotificarProduccion">
        <dc:Bounds x="270" y="220" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- ── LANE: Encargado Cosecha (y=320..440) ── -->
      <bpmndi:BPMNShape id="Task_CreacionActasDigital_di" bpmnElement="Task_CreacionActasDigital">
        <dc:Bounds x="450" y="340" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- ── LANE: Analista Logístico (y=440..680) ── -->
      <bpmndi:BPMNShape id="Task_ValidacionNOC_di" bpmnElement="Task_ValidacionNOC">
        <dc:Bounds x="630" y="490" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_EsNOC_di" bpmnElement="GW_EsNOC" isMarkerVisible="true">
        <dc:Bounds x="805" y="505" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="793" y="562" width="75" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CorreccionEstandar_di" bpmnElement="Task_CorreccionEstandar">
        <dc:Bounds x="920" y="590" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProcesoInventario_di" bpmnElement="Task_ProcesoInventario">
        <dc:Bounds x="1100" y="490" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PreliminarNOC_di" bpmnElement="Task_PreliminarNOC">
        <dc:Bounds x="1280" y="490" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_Timer_Noche_di" bpmnElement="Start_Timer_Noche">
        <dc:Bounds x="1282" y="610" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1256" y="653" width="88" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreacionPedidos_di" bpmnElement="Task_CreacionPedidos">
        <dc:Bounds x="1460" y="490" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- ── LANE: Analista Valorizado (y=680..900) ── -->
      <bpmndi:BPMNShape id="GW_Split_Contratos_di" bpmnElement="GW_Split_Contratos">
        <dc:Bounds x="435" y="715" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreacionContratoSAP_di" bpmnElement="Task_CreacionContratoSAP">
        <dc:Bounds x="540" y="690" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreacionContratoMA_di" bpmnElement="Task_CreacionContratoMA">
        <dc:Bounds x="540" y="790" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreacionContratoCDH_di" bpmnElement="Task_CreacionContratoCDH">
        <dc:Bounds x="540" y="890" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_Join_Contratos_di" bpmnElement="GW_Join_Contratos">
        <dc:Bounds x="715" y="795" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IntegracionSistemas_di" bpmnElement="Task_IntegracionSistemas">
        <dc:Bounds x="820" y="780" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_ContratosCreados_di" bpmnElement="End_ContratosCreados">
        <dc:Bounds x="1015" y="802" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="988" y="845" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Valorización Fase 3 -->
      <bpmndi:BPMNShape id="GW_CambiosVMA_di" bpmnElement="GW_CambiosVMA" isMarkerVisible="true">
        <dc:Bounds x="1475" y="715" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1455" y="772" width="90" height="14"/></bpmndi:BPMNLabel>
